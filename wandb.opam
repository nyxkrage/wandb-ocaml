bug-reports: "https://github.com/nyxkrage/wandb-ocaml/issues"
depends: [
  "ocaml" {>= "5.2"}
  "dune" {>= "3.22"}
  "ocaml-protoc-plugin" {>= "6.2.0"}
  "kaun" {with-dev-setup}
  "odoc" {with-doc}
]
